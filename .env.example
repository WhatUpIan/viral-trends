# Supabase (required in production)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# CreatorCrawl — https://creatorcrawl.com
CREATORCRAWL_API_KEY=

# OpenAI — optional; falls back to heuristic categories/insights/keywords
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SerpAPI — required for web/news brand mentions (https://serpapi.com)
SERPAPI_API_KEY=

# Protect /api/cron/ingest (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Local UI without DB: set true to show mock trends on /
USE_MOCK_REPORT=true
